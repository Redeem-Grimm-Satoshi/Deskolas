msg_file="$1"
dash=$(printf '\342\200\224')
attribution='co-authored-by:[[:space:]]*(claude|anthropic)|generated with \[?claude|generated by claude|ai-generated|ai-assisted'

if grep -nI "$dash" "$msg_file"; then
  echo "Commit message has an em dash. Use a comma, parentheses, a colon, or rewrite."
  exit 1
fi

if grep -nIiE "$attribution" "$msg_file"; then
  echo "Commit message has AI attribution. Write it as the engineer who owns the change."
  exit 1
fi
