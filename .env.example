# Deskolas uses the Supabase integration on Vercel. The integration provisions
# the database and manages these variables for all environments, so you do not
# set them by hand. Pull them into a local .env.local (gitignored) with:
#
#   vercel env pull .env.local
#
# The variables the app and scripts use:
#
# NEXT_PUBLIC_SUPABASE_URL           Supabase project URL. Public.
# NEXT_PUBLIC_SUPABASE_ANON_KEY      Anon key. Public; RLS protects the data.
# SUPABASE_SERVICE_ROLE_KEY          Secret. Server-side only, never NEXT_PUBLIC.
#                                    Used by the seed script and privileged
#                                    server tasks.
# POSTGRES_URL_NON_POOLING           Direct database connection, used only to
#                                    apply migrations (npm run db:push).
#
# The integration also sets POSTGRES_URL, POSTGRES_* and SUPABASE_* aliases that
# the app does not read directly.

# Public base URL, used for auth redirects (OAuth, password reset) and for the
# ticket links sent to Learners Hub. Not managed by the integration; set per
# environment. Local: http://localhost:3000. Vercel: the deployment URL.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Learners Hub knowledge base handoff. All three are server-only (never
# NEXT_PUBLIC) and are exchanged with the KB team over a secure channel, not
# committed. When KB_SUBMISSIONS_URL or KB_API_KEY is unset, promoting a ticket
# still records the local candidate flag but skips the outbound handoff.
#
# KB_SUBMISSIONS_URL   Their submissions endpoint, e.g.
#                      https://<their-project>.supabase.co/rest/v1/submissions
# KB_API_KEY           Their API key, sent as apikey and bearer on the POST.
# KB_WEBHOOK_SECRET    Shared secret we require on their /api/kb/published call.
KB_SUBMISSIONS_URL=""
KB_API_KEY=""
KB_WEBHOOK_SECRET=""
